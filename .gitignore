*.py[cod]
*.pyo
tf_env/
venv/
.venv/

# ── ML — large files not suitable for git ─────────────────────────────────────
# Dataset images (tens of thousands of files, hundreds of MB)
train/
validation/
test/

# Trained model weights (200+ MB each)
saved_model/*.keras

# Temporary upload directory
uploads/

# Keep the class labels JSON (small, needed to run the app)
!saved_model/class_names.json

